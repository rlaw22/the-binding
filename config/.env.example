# The Binding — Environment Configuration
# Copy this file to .env and fill in values as needed.
# Without LLM_API_KEY, the server runs in mock mode (canned DM responses).

# Server
PORT=3000
HOST=0.0.0.0

# LLM Configuration (required for real AI DM)
# Set this to use a real LLM instead of mock responses.
# Any OpenAI-compatible API works (OpenAI, Together, Groq, Novita, etc.)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Phase 2+
# TTS_API_KEY=
# TTS_PROVIDER=elevenlabs
# IMAGE_API_KEY=
# DATABASE_URL=sqlite:./data/binding.db
